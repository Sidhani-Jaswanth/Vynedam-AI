NODE_ENV=production
PORT=5000

# Database
USE_DB=true
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Security
JWT_SECRET=replace-with-a-long-random-secret
REQUIRE_AUTH=true
REQUIRE_AUTH_KEY=false
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
JWT_ALGORITHMS=HS256
JWT_ISSUER=
JWT_AUDIENCE=
JWT_MAX_AGE=
AUTH_KEY_URL=https://your-auth-service.example.com/validate

# AI provider
AI_API_URL=https://your-ai-provider.example.com/v1/chat
AI_API_KEY=replace-with-primary-key
FALLBACK_AI_KEY=
FALLBACK_AI_URL=
AI_SANDBOX_MODE=false
AI_SANDBOX_DELAY_MS=200

# CORS
CORS_ORIGIN=https://your-frontend-domain.com

# Optional backward compatibility route
ENABLE_LEGACY_GENERATE_ROUTE=false

# Preview artifact controls
PREVIEW_REQUIRE_AUTH=false
PREVIEW_TTL_HOURS=24
PREVIEW_CLEANUP_INTERVAL_MINUTES=30

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GENERAL=300
RATE_LIMIT_MAX_AUTH=80
RATE_LIMIT_MAX_GENERATE=60
